APP_NAME="Smart Household Finance Monitor"
APP_ENV=local
APP_KEY=base64:GENERATE_A_NEW_KEY_HERE
APP_DEBUG=true
APP_URL=http://localhost/acchome
APP_LOCALE=en
APP_DIRECTION=ltr

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=acchome
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@household-finance.app
MAIL_FROM_NAME="${APP_NAME}"

CURRENCY=USD
CURRENCY_SYMBOL=$
DATE_FORMAT=Y-m-d
TIMEZONE=Asia/Baghdad
